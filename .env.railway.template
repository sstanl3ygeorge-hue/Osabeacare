# Osabeacare - Railway Environment Variables Template
# Copy these to your Railway service environment variables

# ============================================
# BACKEND SERVICE VARIABLES
# ============================================

# MongoDB (Railway will auto-inject MONGO_URL if you add MongoDB service)
MONGO_URL=${{MongoDB.MONGO_URL}}
DB_NAME=osabeacare_prod

# JWT Secret (generate a secure random string)
JWT_SECRET=your-secure-jwt-secret-min-32-chars

# CORS - Set to your frontend Railway URL
CORS_ORIGINS=https://your-frontend.up.railway.app

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
SENDER_EMAIL=Osabea Recruitment Team <recruitment@osabeacares.co.uk>
REPLY_TO_EMAIL=info@osabeacaresolutions.co.uk
ADMIN_EMAIL=admin@osabea.care

# LLM Integration (Emergent)
EMERGENT_LLM_KEY=sk-emergent-your-key

# Optional: Supabase (if migrating)
# SUPABASE_DB_URL=postgresql://...
# READ_SOURCE_EMPLOYEES=mongo
# READ_SOURCE_COMPLIANCE=mongo
# READ_SOURCE_TRAINING=mongo


# ============================================
# FRONTEND SERVICE VARIABLES
# ============================================

# Backend API URL (set to your backend Railway URL)
REACT_APP_BACKEND_URL=https://your-backend.up.railway.app


# ============================================
# RAILWAY AUTO-INJECTED VARIABLES
# ============================================
# These are automatically set by Railway:
# - PORT (backend/frontend port)
# - RAILWAY_ENVIRONMENT
# - RAILWAY_SERVICE_NAME
# - MongoDB.MONGO_URL (if MongoDB service added)
