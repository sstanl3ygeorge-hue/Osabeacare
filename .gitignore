*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/
*.cover
*.log
.mypy_cache/
.ruff_cache/

# Virtual environments
venv/
ENV/
env/
.venv/

# ==========================================
# Node / React Frontend
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
frontend/build/
frontend/dist/
.next/
out/

# ==========================================
# Environment & Secrets (CRITICAL)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
backend/.env
frontend/.env

# ==========================================
# IDE & Editor
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ==========================================
# Migration Reports (generated)
# ==========================================
migration/reports/*.log
migration/reports/*.json

# ==========================================
# Test Reports (generated)
# ==========================================
test_reports/
*.test.log

# ==========================================
# Misc
# ==========================================
*.bak
*.tmp
*.temp
.cache/
*.pid
*.seed
*.pid.lock

